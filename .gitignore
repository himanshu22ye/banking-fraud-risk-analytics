###########################################################
# Banking Fraud & Risk Analytics
# .gitignore
###########################################################

#############################
# Python
#############################

__pycache__/
*.py[cod]
*$py.class

#############################
# Jupyter Notebooks
#############################

.ipynb_checkpoints/

#############################
# Virtual Environments
#############################

venv/
.venv/
env/
ENV/

#############################
# Conda
#############################

.conda/
conda-meta/

#############################
# Environment Variables
#############################

.env
.env.*

#############################
# IDE Settings
#############################

.vscode/
.idea/

#############################
# Logs
#############################

*.log
logs/

#############################
# Temporary Files
#############################

*.tmp
*.temp

#############################
# Operating System Files
#############################

.DS_Store
Thumbs.db
desktop.ini

#############################
# Power BI
#############################

*.pbix.autosave

#############################
# SQL Server
#############################

*.bak
*.ldf
*.mdf

#############################
# Data
#############################

# Ignore raw datasets
data/raw/*

# Keep folder structure
!data/raw/.gitkeep

# Ignore processed datasets
data/processed/*

# Keep folder structure
!data/processed/.gitkeep

#############################
# Reports
#############################

reports/*.pdf

#############################
# Python Cache
#############################

.pytest_cache/
.mypy_cache/
.cache/

#############################
# Build Files
#############################

build/
dist/
*.egg-info/

#############################
# Coverage
#############################

.coverage
htmlcov/

#############################
# Secrets & Credentials
#############################

secrets/
credentials/
*.pem
*.key

#############################
# Miscellaneous
#############################

*.swp
*.swo