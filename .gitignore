###########################################################
# Banking Fraud & Risk Analytics
# .gitignore
###########################################################

#############################
# Python
#############################

__pycache__/
*.py[cod]
*$py.class

#############################
# Jupyter Notebook
#############################

.ipynb_checkpoints/

#############################
# Virtual Environments
#############################

venv/
.venv/
env/
ENV/

#############################
# Conda
#############################

.conda/
conda-meta/

#############################
# Environment Variables
#############################

.env
.env.*

#############################
# VS Code
#############################

.vscode/

#############################
# PyCharm
#############################

.idea/

#############################
# Logs
#############################

*.log
logs/

#############################
# Temporary Files
#############################

*.tmp
*.temp

#############################
# Operating System
#############################

.DS_Store
Thumbs.db
desktop.ini

#############################
# Power BI
#############################

*.pbix.autosave

#############################
# SQL Server
#############################

*.bak
*.ldf
*.mdf

#############################
# Data
#############################

# Ignore all raw datasets
data/raw/*

# Keep folder structure
!data/raw/.gitkeep

#############################
# Processed Data
#############################

# Uncomment if processed data becomes too large
# data/processed/*

#############################
# Reports
#############################

reports/*.pdf

#############################
# Images (Optional)
#############################

# Uncomment if generated images become large
# images/output/

#############################
# Python Cache
#############################

.pytest_cache/
.mypy_cache/
.cache/

#############################
# Build Files
#############################

build/
dist/
*.egg-info/

#############################
# Coverage
#############################

.coverage
htmlcov/

#############################
# Secrets
#############################

secrets/
credentials/
*.pem
*.key

###########################################################
# End
